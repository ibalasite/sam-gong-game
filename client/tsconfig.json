{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "cc": ["./tests/__mocks__/cc.ts"]
    }
  },
  "include": ["assets/scripts/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
